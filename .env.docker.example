# =============================================================================
# Docker / AWS production environment
# Copy: cp .env.docker.example .env
# =============================================================================

APP_NAME=Viveride
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://www.viveride.online
APP_FOR=production

LOG_CHANNEL=daily
LOG_LEVEL=error

# Docker service name — do NOT use 127.0.0.1
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=viveride
DB_USERNAME=viveride
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@viveride.online"
MAIL_FROM_NAME="${APP_NAME}"

# Docker ports (host mapping)
HTTP_PORT=80
HTTPS_PORT=443
MYSQL_PORT=3306

# Container behaviour
RUN_MIGRATIONS=true
WAIT_FOR_DB=true

VITE_APP_NAME="${APP_NAME}"
