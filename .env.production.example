# Copy to .env.prod and fill secrets, or use the committed .env.prod on deploy.
# Local dev uses .env.local (port 3308). Production uses .env.prod (port 3306 on server).
# Same DB user/password/database name — separate MySQL volumes = separate data.

APP_NAME=viberidegh
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://viberidegh.online
APP_FOR=production

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=viverider
DB_USERNAME=viverider_usr
DB_PASSWORD=
DB_ROOT_PASSWORD=

SESSION_SECURE_COOKIE=true
SESSION_DOMAIN=viberidegh.online

FIREBASE_CREDENTIALS=/var/www/viverider/public/push-configurations/firebase.json

# Deploy auto-switches to http:// and SESSION_SECURE_COOKIE=false when SSL cert is missing.
