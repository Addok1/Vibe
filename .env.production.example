# Copy to .env.prod and fill secrets, or use deploy/production.env on deploy.
# Local: .env.local (DB_PORT=3308). Production: deploy/production.env (DB_PORT=3306).
# Same DB credentials — separate MySQL volumes = separate data.

APP_NAME=viberidegh
APP_ENV=production
NODE_ENV=production
APP_KEY=
APP_DEBUG=false
# Use http:// until real SSL is live; then switch to https://
APP_URL=http://viberidegh.online
APP_FOR=production

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=viverider
DB_USERNAME=viverider_usr
DB_PASSWORD=
DB_ROOT_PASSWORD=

# Session — keep identical local + production rules (prevents 419 Session expired)
SESSION_DRIVER=database
SESSION_LIFETIME=480
SESSION_COOKIE=viberide_session
SESSION_SAME_SITE=lax
# Do NOT set SESSION_DOMAIN (host-only cookies work on IP + domain)
# Do NOT set SESSION_SECURE_COOKIE (null/auto: HTTP ok, HTTPS ok behind nginx)

FIREBASE_CREDENTIALS=/var/www/viverider/public/push-configurations/firebase.json
